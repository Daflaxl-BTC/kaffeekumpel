# Kaffeekumpel — Umgebungsvariablen
# Kopiere diese Datei nach .env.local und fülle die Werte aus.
# .env.local NICHT einchecken (steht in .gitignore).

# Supabase — Projekt URL & Keys (aus Dashboard: Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...HIER_AUS_DASHBOARD_EINFUEGEN

# Service-Role-Key: AUS DEM DASHBOARD ziehen (Settings → API → service_role, "Reveal" klicken).
# Niemals client-seitig exposen.
SUPABASE_SERVICE_ROLE_KEY=HIER_AUS_DASHBOARD_EINFUEGEN

# Supabase JWT Secret — signiert kurzlebige Realtime-Tokens (Route: /api/realtime-token).
# Ohne diesen Key sieht der Browser keine Realtime-Events, weil die events-Policy
# seit dem Security-Audit 2026-04-19 nur JWTs mit passender group_ids-Claim durchlässt.
# Holen: Dashboard → Settings → API → "JWT Secret" (unter den Project API keys).
SUPABASE_JWT_SECRET=HIER_AUS_DASHBOARD_EINFUEGEN

# Session-Cookie Signatur-Secret. Generieren mit:
#   openssl rand -base64 32
SESSION_SECRET=HIER_ZUFAELLIGEN_32BYTE_STRING_EINFUEGEN

# App-URL (lokal: http://localhost:3000, prod: https://deine-domain.de)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic API-Key für den PDF-Rückblick (Titel, Fun-Fact, persönliche Kommentare).
# Ohne Key greift ein harmloser Fallback-Text – das PDF wird trotzdem generiert.
# Key holen: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: lokaler Pfad zu einem Chrome/Edge-Binary für Puppeteer im Dev.
# Ungesetzt → Auto-Detection probiert macOS/Windows/Linux-Standardpfade.
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
